# ──────────────────────────────────────────────────────────────────────────────
# Deployment-level settings consumed by docker-compose.
# Copy to ".env" (next to docker-compose.yml) and fill in.
# ──────────────────────────────────────────────────────────────────────────────

# Database — created inside the Postgres container, and passed to the backend.
DB_NAME=pvc_admin
DB_USER=pvc_user
DB_PASSWORD=CHANGE_ME_strong_db_password

# Public address Caddy serves on:
#   • Real hostname → automatic free HTTPS (recommended):
#       SITE_ADDRESS=pvcadmin.duckdns.org
#   • Quick HTTP-only test on the server IP (logins won't persist — no HTTPS):
#       SITE_ADDRESS=:80
SITE_ADDRESS=:80
