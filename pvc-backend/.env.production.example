# ──────────────────────────────────────────────────────────────────────────────
# PVC Admin Backend — PRODUCTION env (used by docker-compose).
# Copy to "pvc-backend/.env.production" and fill in.
#
# NOTE: Database connection (DB_HOST/PORT/NAME/USER/PASSWORD) and REDIS_ENABLED
#       are injected by docker-compose from the root .env — do NOT set them here.
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=4000
APP_NAME=PVC Distributor Admin

# ── Public URLs ────────────────────────────────────────────────────────────────
# Use your real site, e.g. https://pvcadmin.duckdns.org  (no trailing slash).
# For a quick HTTP-only IP test use http://YOUR_SERVER_IP  (logins won't persist).
APP_URL=https://CHANGE_ME_your_host
FRONTEND_URL=https://CHANGE_ME_your_host
CORS_ORIGINS=https://CHANGE_ME_your_host

# ── JWT / security ──────────────────────────────────────────────────────────────
# Generate your own: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_long_random_hex
JWT_REFRESH_SECRET=CHANGE_ME_different_long_random_hex
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
SESSION_SECRET=CHANGE_ME_another_long_random_hex

# ── Email (SMTP) ────────────────────────────────────────────────────────────────
# Gmail (real delivery): create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME@gmail.com
SMTP_PASS=CHANGE_ME_16_char_app_password
MAIL_FROM_NAME=PVC Admin
MAIL_FROM_ADDRESS=CHANGE_ME@gmail.com

# ── Rate limiting ───────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# ── Files / logging ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
UPLOAD_MAX_SIZE=5242880
LOG_LEVEL=info
LOG_DIR=logs

# ── Business / cron ─────────────────────────────────────────────────────────────
MAKER_CHECKER_ORDER_THRESHOLD=100000
CHEQUE_REMINDER_DAYS=2
OVERDUE_GRACE_DAYS=0
ALERT_CRON_SCHEDULE=0 8 * * *
BACKUP_CRON_SCHEDULE=0 2 * * *
BACKUP_DIR=backups
BACKUP_RETAIN_DAYS=30
