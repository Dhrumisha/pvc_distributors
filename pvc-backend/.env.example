# ══════════════════════════════════════════════════════════════════════════════
# PVC DISTRIBUTOR ADMIN — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=4000
APP_NAME=PVC Distributor Admin
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000       # ← CRITICAL: reset/invite links in emails point here. Change to your real domain in production
CORS_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=pvc_admin
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_DEBUG=false

# ── Redis (optional) ──────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=pvc:
REDIS_PERMISSION_CACHE_TTL=300

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate strong secrets:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_64_CHAR_RANDOM_SECRET
JWT_REFRESH_SECRET=CHANGE_THIS_DIFFERENT_64_CHAR_RANDOM_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ══════════════════════════════════════════════════════════════════════════════
# EMAIL (SMTP) — Sends real emails to real inboxes
# ══════════════════════════════════════════════════════════════════════════════
#
# When configured, these emails are sent TO THE RECIPIENT'S ACTUAL INBOX:
#   • Forgot password → reset link sent to the user's email
#   • New user invite → set-password link sent to the new user's email
#   • Password changed → confirmation sent to the user's email
#
# The FROM address is your Gmail (or whatever SMTP provider you use).
# The TO address is the recipient — they receive it in their real inbox.
#
# ────────────────────────────────────────────────────────────────────────────
# GMAIL SETUP (recommended — free, works immediately)
# ────────────────────────────────────────────────────────────────────────────
# Step 1: Enable 2-Step Verification on your Google Account
#         → https://myaccount.google.com/security
#         → Click "2-Step Verification" → Follow setup
#
# Step 2: Create an App Password (NOT your regular Gmail password)
#         → https://myaccount.google.com/apppasswords
#         → Select app: "Mail"
#         → Select device: "Other (Custom name)" → type "PVC Admin"
#         → Click Generate
#         → Copy the 16-character password shown (e.g. abcd efgh ijkl mnop)
#
# Step 3: Fill in the values below:
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail_address@gmail.com      # ← Your Gmail address
SMTP_PASS=abcdefghijklmnop                  # ← The 16-char App Password (spaces optional)
MAIL_FROM_NAME=PVC Admin
MAIL_FROM_ADDRESS=your_gmail_address@gmail.com
#
# Result: Emails are sent FROM your_gmail_address@gmail.com
#                          TO   the recipient's actual inbox
#
# Test it: After starting the server, call:
#   POST /api/v1/alerts/test  { "type": "email", "recipient": "someone@gmail.com" }
#   Or use the Admin Panel → Alerts → Send Test Email
#
# ────────────────────────────────────────────────────────────────────────────
# MAILGUN (for production / custom domain)
# ────────────────────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=postmaster@mg.yourdomain.com
# SMTP_PASS=your_mailgun_smtp_password
# MAIL_FROM_NAME=PVC Admin
# MAIL_FROM_ADDRESS=noreply@yourdomain.com

# ────────────────────────────────────────────────────────────────────────────
# SENDGRID (for production)
# ────────────────────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG.your_sendgrid_api_key_here
# MAIL_FROM_NAME=PVC Admin
# MAIL_FROM_ADDRESS=noreply@yourdomain.com

# ────────────────────────────────────────────────────────────────────────────
# MAILTRAP (development only — catches emails, does NOT deliver to inbox)
# Good for testing email templates without sending real emails.
# Sign up free: https://mailtrap.io
# ────────────────────────────────────────────────────────────────────────────
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_SECURE=false
# SMTP_USER=your_mailtrap_inbox_user
# SMTP_PASS=your_mailtrap_inbox_password
# MAIL_FROM_NAME=PVC Admin
# MAIL_FROM_ADDRESS=noreply@pvcdist.com

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
UPLOAD_MAX_SIZE=5242880

# ── Security ──────────────────────────────────────────────────────────────────
MAKER_CHECKER_ORDER_THRESHOLD=100000
SESSION_SECRET=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_STRING

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs

# ── Alerts / Cron ─────────────────────────────────────────────────────────────
CHEQUE_REMINDER_DAYS=2
OVERDUE_GRACE_DAYS=0
ALERT_CRON_SCHEDULE=0 8 * * *

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_CRON_SCHEDULE=0 2 * * *
BACKUP_DIR=backups
BACKUP_RETAIN_DAYS=30
