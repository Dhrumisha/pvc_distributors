# pvc-website (public storefront) — Vercel environment variables
#
# Server-side only (used in Server Components / route handlers — no CORS, no NEXT_PUBLIC_).
# Point this at the Render backend's public API, WITH the /api/v1 suffix.
#
#   API_BASE_URL = https://pvc-backend-xxxx.onrender.com/api/v1
#
# Locally it defaults to http://localhost:4000/api/v1 if unset.
API_BASE_URL=https://pvc-backend-xxxx.onrender.com/api/v1
