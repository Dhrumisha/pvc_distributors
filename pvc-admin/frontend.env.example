# ══════════════════════════════════════════════════════════════════════════════
# PVC DISTRIBUTOR ADMIN — FRONTEND (Next.js)
# File: .env.local
# Copy this file to .env.local and fill in your actual values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser bundle.
# Variables WITHOUT that prefix are only available on the server side (SSR).
# Never commit the real .env.local file to git — only commit this .env.example
# ══════════════════════════════════════════════════════════════════════════════


# ── API CONNECTION ────────────────────────────────────────────────────────────
# URL of your Node.js backend API.
# Change this to your production domain when deploying.
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Timeout for API requests in milliseconds (30 seconds)
NEXT_PUBLIC_API_TIMEOUT=30000


# ── APP METADATA ──────────────────────────────────────────────────────────────
# Shown in browser title bar and meta tags
NEXT_PUBLIC_APP_NAME=PVC Admin
NEXT_PUBLIC_APP_TAGLINE=Distributor Management System
NEXT_PUBLIC_APP_VERSION=1.0.0

# Your business name (shown in sidebar footer and emails)
NEXT_PUBLIC_COMPANY_NAME=Your Company Name Here


# ── THEMING ───────────────────────────────────────────────────────────────────
# These are read by the theme system at build time.
# After changing these, restart the dev server.

# Primary accent colour (hex) — used for buttons, highlights, badges
# Current: warm amber. Change to any hex to retheme the entire admin.
NEXT_PUBLIC_ACCENT_COLOR=#f59e0b

# App logo URL (leave empty to use the default Package icon)
NEXT_PUBLIC_LOGO_URL=


# ── CURRENCY & LOCALE ─────────────────────────────────────────────────────────
# Used for formatting monetary values throughout the admin
NEXT_PUBLIC_CURRENCY_SYMBOL=₹
NEXT_PUBLIC_CURRENCY_CODE=INR
NEXT_PUBLIC_LOCALE=en-IN
NEXT_PUBLIC_TIMEZONE=Asia/Kolkata

# Date format shown in tables and forms (dayjs / date-fns format string)
NEXT_PUBLIC_DATE_FORMAT=DD MMM YYYY
NEXT_PUBLIC_DATETIME_FORMAT=DD MMM YYYY, hh:mm A


# ── PAGINATION ────────────────────────────────────────────────────────────────
# Default number of rows per page in all tables
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=20


# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────
# Set to true to enable features in the UI.
# Backend must also support the feature for it to work end-to-end.

# Show the GST / e-Invoice section in billing
NEXT_PUBLIC_FEATURE_EINVOICE=false

# Show WhatsApp share button on invoices and quotations
NEXT_PUBLIC_FEATURE_WHATSAPP_SHARE=true

# Show barcode scanner button (Phase 2 feature)
NEXT_PUBLIC_FEATURE_BARCODE_SCAN=false

# Enable the customer-facing portal link (Phase 2)
NEXT_PUBLIC_FEATURE_CUSTOMER_PORTAL=false

# Show the multi-godown selector (Phase 2)
NEXT_PUBLIC_FEATURE_MULTI_GODOWN=false


# ── ANALYTICS (optional) ──────────────────────────────────────────────────────
# Google Analytics measurement ID — leave empty to disable
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Sentry DSN for frontend error tracking — leave empty to disable
NEXT_PUBLIC_SENTRY_DSN=


# ── MAPS (optional — for delivery route display) ──────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=


# ── SERVER-SIDE ONLY (no NEXT_PUBLIC_ prefix — not exposed to browser) ────────
# These are only available in Next.js API routes and server components.

# Used if you add any server-side API calls (e.g. in route handlers)
API_INTERNAL_URL=http://localhost:4000/api/v1

# Secret for signing any server-side cookies set by Next.js
NEXTAUTH_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_FOR_SERVER_SIDE_USE
NEXTAUTH_URL=http://localhost:3000
